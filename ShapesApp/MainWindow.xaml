<Window x:Class="ShapesApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📐 Фабричный метод - Создание фигур" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и ComboBox -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="Выберите цвет фигур:" 
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#333333"
                       Margin="0,0,0,15"
                       HorizontalAlignment="Center"/>

            <ComboBox x:Name="colorComboBox" 
                      SelectionChanged="ColorComboBox_SelectionChanged"
                      Width="300" 
                      Height="45"
                      FontSize="18"
                      HorizontalAlignment="Center"
                      VerticalContentAlignment="Center">
                <ComboBoxItem Content="🔴 Красный"/>
                <ComboBoxItem Content="🔵 Синий"/>
                <ComboBoxItem Content="🟢 Зелёный"/>
            </ComboBox>
        </StackPanel>

        <!-- Панель с фигурами -->
        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20">
            <StackPanel x:Name="figuresPanel" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>